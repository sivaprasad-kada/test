# ─────────────────────────────────────────────────────
# URL Shortener — Environment Variables
# ─────────────────────────────────────────────────────

# Redis connection URL
REDIS_URL=redis://localhost:6379

# MongoDB connection URI
MONGO_URI=mongodb://localhost:27017/url-shortener

# Server port
PORT=5000

# Frontend URL (for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:8080

# BullMQ worker concurrency (number of jobs processed in parallel)
QUEUE_CONCURRENCY=5

# Cache TTL for URL mappings (in seconds) — default 24 hours
CACHE_TTL=86400

# Aggregation sync interval (cron expression) — default every 5 minutes
AGGREGATION_CRON=*/5 * * * *

# ─── OAuth (Google) ──────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ─── OAuth (GitHub) ──────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# Secret key used for short URL obfuscation (XOR secret key)
SHORT_CODE_SECRET=1515870810
